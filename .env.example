# 🔑 Environment Variables for Railway Deployment
# Copy these into the Railway dashboard and replace with real values.
# This file holds PLACEHOLDERS ONLY — never commit real keys.

# OpenAI API (Required: story generation, image generation, transcription)
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# OpenAI image model (DALL-E 2/3 were deprecated May 12, 2026 — gpt-image-* replaces them).
# Defaults shown below; only set these to override.
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_SIZE=1024x1024

# Google Cloud Storage bucket for hosting generated images.
# gpt-image-* returns base64 (not a temporary URL), so the backend uploads each
# image here and returns a public https://storage.googleapis.com/<bucket>/... URL.
# The bucket must grant public read access (allUsers -> Storage Object Viewer).
GCS_IMAGE_BUCKET=your-image-bucket-name

# Google Cloud service account credentials — used for BOTH Text-to-Speech and
# image hosting. Preferred: paste the full service-account JSON as the value of
# GOOGLE_CLOUD_CREDENTIALS_JSON in the Railway dashboard; the server writes it to
# a temp file at startup.
GOOGLE_CLOUD_CREDENTIALS_JSON={"type":"service_account", ... }

# ElevenLabs API (Alternative TTS service)
ELEVENLABS_API_KEY=sk_your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=your_preferred_voice_id

# Railway automatically sets PORT - do not set this manually
# PORT=3001
